# URL of the Digital Formulator FastAPI backend.
# Copy this file to .env and uncomment the line that matches your setup.

# --- Same machine (API and dashboard running locally, outside Docker) ---
# API_BASE_URL=http://localhost:8000

# --- Same machine (API in Docker Compose, using service name) ---
# API_BASE_URL=http://dm2_api:8000

# --- Same machine (API in Docker, dashboard on host — Docker Desktop) ---
# API_BASE_URL=http://host.docker.internal:8000

# --- Remote / different machine ---
API_BASE_URL=http://130.159.77.49:8000
